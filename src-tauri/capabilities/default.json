{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop capability for the app window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download",
    "updater:allow-install",
    "allow-get-app-state",
    "allow-add-hf-model",
    "allow-add-model-from-preset",
    "allow-set-active-model",
    "allow-update-runtime-settings",
    "allow-create-chat",
    "allow-set-active-chat",
    "allow-delete-chat",
    "allow-start-download-model",
    "allow-start-model-server",
    "allow-stop-model-server",
    "allow-chat-with-model",
    "allow-download-llama-cpp",
    "allow-complete-onboarding",
    "allow-check-app-updates",
    "allow-search-hf-models",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-minimize",
    "core:window:allow-unminimize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "core:window:allow-start-dragging",
    "core:window:allow-set-focus",
    "core:window:allow-is-visible"
  ]
}
